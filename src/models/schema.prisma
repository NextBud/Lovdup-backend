generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Core Auth & Account Models
// ---------------------------------------------------------------------------

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  passwordHash           String?
  phone                  String?               @unique
  whatsappPhone          String?
  emailVerified          Boolean               @default(false)
  phoneVerified          Boolean               @default(false)
  verified               Boolean               @default(false)
  role                   UserRole              @default(USER)
  status                 UserStatus            @default(ACTIVE)
  isActive               Boolean               @default(true)
  isSuspended            Boolean               @default(false)
  pausedAt               DateTime?
  pausedReason           String?
  pausedAdditionalNote   String?
  deletedAt              DateTime?
  permanentDeletionAt    DateTime?
  deletedReason          String?
  deletedAdditionalNote  String?
  lastLoginAt            DateTime?
  lastActiveAt           DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  photosProcessingStatus MediaProcessingStatus @default(UPLOADING)
  voiceProcessingStatus  MediaProcessingStatus @default(UPLOADING)
  campaignsCreated       Campaign[]            @relation("CampaignCreator")
  isInfluencer           Boolean               @default(false)
  influencerProfile      InfluencerProfile?

  // Referral Relations
  referralCode      ReferralCode?
  referralsMade     Referral[]         @relation("Referrer")
  referralReceived  Referral?          @relation("ReferredUser")
  influencerProfile InfluencerProfile?

  // Reward Relations
  referralRewards ReferralReward[]

  // Relations
  conversationUnlocks   ConversationUnlock[]
  authProviders         AuthProvider[]
  compatibilityAsUserA  CompatibilityScore[] @relation("CompatibilityUserA")
  compatibilityAsUserB  CompatibilityScore[] @relation("CompatibilityUserB")
  matchesAsUserA        Match[]              @relation("MatchUserA")
  matchesAsUserB        Match[]              @relation("MatchUserB")
  matchPreference       MatchPreference?
  receivedMatchRequests MatchRequest[]       @relation("ReceivedMatchRequests")
  sentMatchRequests     MatchRequest[]       @relation("SentMatchRequests")
  candidateMatchResults MatchResult[]        @relation("CandidateMatchResults")
  viewedMatchResults    MatchResult[]        @relation("ViewerMatchResults")
  onboardingMedia       OnboardingMedia[]
  onboardingProgress    OnboardingProgress?
  profile               Profile?
  profilePhotos         ProfilePhoto[]
  refreshSessions       RefreshSession[]
  voiceAnswers          VoiceAnswer[]
  wallet                Wallet?
  coinPurchases         CoinPurchase[]
  walletTransactions    WalletTransaction[]
  messages              Message[]
  blocksCreated         UserBlock[]          @relation("UserBlocksCreated")
  blocksReceived        UserBlock[]          @relation("UserBlocksReceived")
  payouts               Payout[]

  // Direct Conversation relationship tracking
  conversationsAsUserA Conversation[] @relation("ConversationUserA")
  conversationsAsUserB Conversation[] @relation("ConversationUserB")
}

// ---------------------------------------------------------------------------
// Campaign Models
// ---------------------------------------------------------------------------

model Campaign {
  id          String         @id @default(uuid())
  name        String
  description String?
  type        CampaignType
  status      CampaignStatus
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy       User                  @relation("CampaignCreator", fields: [createdById], references: [id])
  campaignRewards CampaignReward[]
  participants    CampaignParticipant[]
  referrals       Referral[]

  @@index([status])
  @@index([type])
  @@index([createdById])
}

model CampaignReward {
  id              String                  @id @default(uuid())
  campaignId      String
  rewardType      RewardType
  participantType CampaignParticipantType
  amount          Decimal                 @db.Decimal(10, 2)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, participantType])
  @@index([campaignId])
  @@index([participantType])
}

model CampaignParticipant {
  id                  String                    @id @default(uuid())
  campaignId          String
  influencerProfileId String
  commissionOverride  Decimal?                  @db.Decimal(10, 2)
  status              CampaignParticipantStatus
  joinedAt            DateTime                  @default(now())

  campaign          Campaign          @relation(fields: [campaignId], references: [id])
  influencerProfile InfluencerProfile @relation(fields: [influencerProfileId], references: [id])
  referrals         Referral[]

  @@unique([campaignId, influencerProfileId])
  @@index([campaignId])
  @@index([influencerProfileId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Referral Models
// ---------------------------------------------------------------------------

model ReferralCode {
  id            String    @id @default(uuid())
  userId        String    @unique
  code          String    @unique
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  regeneratedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[]
  clicks    ReferralClick[]

  @@index([code])
  @@index([isActive])
  @@index([userId])
}

model Referral {
  id                    String         @id @default(uuid())
  campaignId            String?
  campaignParticipantId String?
  referralCodeId        String
  referrerId            String
  referredUserId        String         @unique
  rewardType            RewardType     @default(COINS)
  rewardAmount          Decimal        @default(100) @db.Decimal(10, 2)
  status                ReferralStatus @default(PENDING)
  clickedAt             DateTime?
  registeredAt          DateTime?      @default(now())
  qualifiedAt           DateTime?
  rewardedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?
  metadata              Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  campaign            Campaign?            @relation(fields: [campaignId], references: [id])
  campaignParticipant CampaignParticipant? @relation(fields: [campaignParticipantId], references: [id])
  referralCode        ReferralCode         @relation(fields: [referralCodeId], references: [id])
  referrer            User                 @relation("Referrer", fields: [referrerId], references: [id])
  referredUser        User                 @relation("ReferredUser", fields: [referredUserId], references: [id])
  reward              ReferralReward?
  clicks              ReferralClick[]

  @@index([referrerId])
  @@index([referredUserId])
  @@index([status])
  @@index([campaignId])
  @@index([campaignParticipantId])
  @@index([referralCodeId])
  @@index([createdAt])
}

model ReferralReward {
  id            String          @id @default(uuid())
  referralId    String          @unique
  beneficiaryId String
  status        RewardStatus    @default(PENDING)
  processor     RewardProcessor @default(SYSTEM)
  processedAt   DateTime?
  payoutId      String?
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  referral    Referral @relation(fields: [referralId], references: [id])
  beneficiary User     @relation(fields: [beneficiaryId], references: [id])
  payout      Payout?  @relation(fields: [payoutId], references: [id])

  @@index([beneficiaryId])
  @@index([status])
  @@index([payoutId])
  @@index([processor])
}

model InfluencerReferral {
  id               String              @id @default(uuid())
  influencerId     String              // FK to InfluencerProfile
  referredUserId   String              @unique // FK to User
  referralCode     String              // The code used
  status           ReferralStatus      @default(PENDING)
  clickedAt        DateTime?
  registeredAt     DateTime            @default(now())
  onboardedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id])
  referredUser User              @relation(fields: [referredUserId], references: [id])

  @@index([influencerId])
  @@index([referredUserId])
  @@index([status])
}


model ReferralClick {
  id                String         @id @default(uuid())
  referralCodeId    String
  referralId        String?
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  country           String?
  source            ReferralSource @default(DIRECT_LINK)
  failureReason     String?
  converted         Boolean        @default(false)
  clickedAt         DateTime       @default(now())

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referral     Referral?    @relation(fields: [referralId], references: [id])

  @@index([referralCodeId])
  @@index([referralId])
  @@index([source])
  @@index([converted])
  @@index([clickedAt])
}

// ---------------------------------------------------------------------------
// Influencer Models
// ---------------------------------------------------------------------------

model InfluencerProfile {
  id               String            @id @default(uuid())
  userId           String            @unique
  brandName        String?
  paymentMethod    PaymentMethod?
  paymentReference String?
  status           InfluencerStatus  @default(ACTIVE)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  socials          InfluencerSocial[]
  payouts          Payout[]
  campaignParticipants CampaignParticipant[]
  earnings InfluencerEarning[]

  @@index([userId])
  @@index([status])
}

model InfluencerEarning {
  id               String           @id @default(uuid())
  influencerId     String           // FK to InfluencerProfile
  referredUserId   String           // FK to User who bought coins
  purchaseId       String           // FK to CoinPurchase
  purchaseAmount   Decimal          @db.Decimal(10, 2) // Total purchase amount
  commissionAmount Decimal          @db.Decimal(10, 2) // 20% of purchase
  status           EarningStatus    @default(PENDING)
  paidOut          Boolean          @default(false)
  payoutId         String?          // FK to Payout
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id])
  referredUser User              @relation(fields: [referredUserId], references: [id])
  purchase     CoinPurchase      @relation(fields: [purchaseId], references: [id])
  payout       Payout?           @relation(fields: [payoutId], references: [id])

  @@index([influencerId])
  @@index([referredUserId])
  @@index([purchaseId])
  @@index([status])
  @@index([paidOut])
}


model InfluencerSocial {
  id           String         @id @default(uuid())
  influencerId String
  platform     SocialPlatform
  handle       String
  url          String?
  followers    Int?
  verified     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@unique([influencerId, platform])
  @@index([influencerId])
  @@index([platform])
  @@index([handle])
}

// ---------------------------------------------------------------------------
// Payout Models
// ---------------------------------------------------------------------------

model Payout {
  id                  String           @id @default(uuid())
  influencerProfileId String
  amount              Decimal          @db.Decimal(10, 2)
  status              PayoutStatus     @default(PENDING)
  provider            PaymentProvider?
  providerReference   String?
  paidAt              DateTime?
  batchId             String?
  metadata            Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  influencerProfile InfluencerProfile @relation(fields: [influencerProfileId], references: [id])
  rewards           ReferralReward[]
  user              User?             @relation(fields: [userId], references: [id])
  userId            String?

  @@index([influencerProfileId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@index([batchId])
}

// ---------------------------------------------------------------------------
// Conversation & Messaging Models
// ---------------------------------------------------------------------------

model ConversationUnlock {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  stage          Int
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId, stage])
  @@index([conversationId])
  @@index([userId])
  @@index([stage])
}

model AuthProvider {
  id          String           @id @default(uuid())
  userId      String
  provider    AuthProviderType
  providerUid String
  linkedAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
}

model RefreshSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @updatedAt
  expiresAt        DateTime
  revokedAt        DateTime?
  isRevoked        Boolean   @default(false)
  rotationCount    Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Onboarding Models
// ---------------------------------------------------------------------------

model OnboardingProgress {
  id                String           @id @default(uuid())
  userId            String           @unique
  status            OnboardingStatus @default(NOT_STARTED)
  maxReachedStep    Int              @default(1)
  currentStep       Int              @default(1)
  completedSections String[]         @default([])
  draftData         Json?
  draftVersion      Int              @default(1)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OnboardingMedia {
  id        String   @id @default(uuid())
  userId    String
  url       String
  publicId  String
  mimeType  String
  size      Int
  mediaType String
  position  Int?
  promptId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mediaType])
}

// ---------------------------------------------------------------------------
// Profile Container & Sub-models
// ---------------------------------------------------------------------------

model Profile {
  id                     String                @id @default(uuid())
  userId                 String                @unique
  onboardingCompleted    Boolean               @default(false)
  completedAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  completionPercent      Int                   @default(0)
  photosProcessingStatus MediaProcessingStatus @default(UPLOADING)
  voiceProcessingStatus  MediaProcessingStatus @default(UPLOADING)

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity      ProfileIdentity?
  lifestyle     ProfileLifestyle?
  narrative     ProfileNarrative?
  profilePhotos ProfilePhoto[]
  values        ProfileValues?
  voiceAnswers  VoiceAnswer[]
}

model ProfileIdentity {
  id                    String   @id @default(uuid())
  profileId             String   @unique
  firstName             String
  lastName              String
  birthDate             DateTime
  gender                Gender
  originCountry         String
  residenceCountry      String
  residenceCity         String
  ethnicity             String?
  languages             String[]
  occupation            String
  relationshipIntention String?
  education             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProfileLifestyle {
  id                 String   @id @default(uuid())
  profileId          String   @unique
  drinking           String
  smoking            String
  socialLife         String
  fitnessImportance  String
  moneyStyle         String
  relocationFeelings String
  financialStatus    String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProfileValues {
  id                  String   @id @default(uuid())
  profileId           String   @unique
  religion            String
  religionImportance  String
  childrenPreference  String
  hasChildren         Boolean  @default(false)
  personalCommStyle   String
  personalTuesdayVibe String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProfileNarrative {
  id        String   @id @default(uuid())
  profileId String   @unique
  aboutMe   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProfilePhoto {
  id               String                @id @default(uuid())
  userId           String
  profileId        String
  url              String
  publicId         String
  mimeType         String
  size             Int
  position         Int
  isPrimary        Boolean               @default(false)
  status           MediaStatus           @default(ACTIVE)
  moderationStatus MediaModerationStatus @default(PENDING)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, position])
  @@index([userId])
  @@index([profileId])
}

// ---------------------------------------------------------------------------
// Voice Interaction Models - FIXED: Added order field and indexes
// ---------------------------------------------------------------------------

model VoicePrompt {
  id        String        @id @default(uuid())
  question  String
  category  String?
  order     Int           @default(0) // 👈 ADDED for consistent ordering
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  answers   VoiceAnswer[]

  @@index([order]) // 👈 ADDED for sorting queries
  @@index([isActive]) // 👈 ADDED for filtering active prompts
}

model VoiceAnswer {
  id                  String                @id @default(uuid())
  userId              String
  profileId           String
  voicePromptId       String
  url                 String
  publicId            String
  mimeType            String
  size                Int
  durationSeconds     Int?
  transcript          String?
  status              MediaStatus           @default(ACTIVE)
  moderationStatus    MediaModerationStatus @default(PENDING)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  language            String?
  processingError     String?
  transcriptionStatus String?
  waveformUrl         String?

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voicePrompt VoicePrompt @relation(fields: [voicePromptId], references: [id])

  @@unique([profileId, voicePromptId])
  @@index([userId])
  @@index([profileId])
  @@index([voicePromptId])
}

// ---------------------------------------------------------------------------
// Matching & Discovery Models
// ---------------------------------------------------------------------------

model MatchPreference {
  id                           String   @id @default(uuid())
  userId                       String   @unique
  preferredGenders             Gender[]
  ageMin                       Int      @default(18)
  ageMax                       Int      @default(99)
  locationPreference           String
  religionPreference           String
  culturePreference            String
  childrenPreference           String
  faithPractice                String
  energyDescription            String
  communicationStyle           String
  tuesdayFeeling               String
  energyMatchStyle             String
  ambitionImportance           String
  socialLevel                  String
  lifestylePreference          String
  financialStabilityPreference String
  financialStagePreference     String
  idealPartnerType             String
  matchVoicePrompt             String
  minCompatibilityScore        Int      @default(50)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompatibilityScore {
  id             String        @id @default(uuid())
  userAId        String
  userBId        String
  score          Int
  identityScore  Int           @default(0)
  lifestyleScore Int           @default(0)
  valuesScore    Int           @default(0)
  locationScore  Int           @default(0)
  reasons        Json?
  calculatedAt   DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  matchResults   MatchResult[]

  userA User @relation("CompatibilityUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("CompatibilityUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([score])
}

model MatchRequest {
  id           String             @id @default(uuid())
  senderId     String
  receiverId   String
  type         MatchRequestType   @default(LIKE)
  status       MatchRequestStatus @default(PENDING)
  message      String?
  respondedAt  DateTime?
  expiresAt    DateTime?
  voiceNoteUrl String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  receiver     User               @relation("ReceivedMatchRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender       User               @relation("SentMatchRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([type])
}

model Match {
  id              String      @id @default(uuid())
  userAId         String
  userBId         String
  status          MatchStatus @default(ACTIVE)
  matchedAt       DateTime    @default(now())
  unmatchedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  unmatchedBy     String?
  unmatchedReason String?

  userA        User          @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB        User          @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  conversation Conversation?

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([status])
}

model MatchResult {
  id                   String  @id @default(uuid())
  viewerId             String
  candidateId          String
  compatibilityScoreId String?

  rank  Int?
  score Int?

  reason MatchResultReason

  shownAt   DateTime  @default(now())
  actedAt   DateTime?
  dismissed Boolean   @default(false)

  candidate          User                @relation("CandidateMatchResults", fields: [candidateId], references: [id], onDelete: Cascade)
  compatibilityScore CompatibilityScore? @relation(fields: [compatibilityScoreId], references: [id])
  viewer             User                @relation("ViewerMatchResults", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([viewerId, candidateId])
  @@index([viewerId])
  @@index([candidateId])
  @@index([reason])
  @@index([dismissed])
}

// ---------------------------------------------------------------------------
// Messaging & Conversation Models
// ---------------------------------------------------------------------------

model Conversation {
  id      String  @id @default(uuid())
  matchId String  @unique
  userAId String?
  userBId String?
  stage   Int     @default(1)

  userAStage2 Boolean @default(false)
  userBStage2 Boolean @default(false)
  userAStage3 Boolean @default(false)
  userBStage3 Boolean @default(false)
  userAStage4 Boolean @default(false)
  userBStage4 Boolean @default(false)
  userAStage5 Boolean @default(false)
  userBStage5 Boolean @default(false)

  stageStartedAt    DateTime           @default(now())
  lastActivityAt    DateTime           @default(now())
  status            ConversationStatus @default(ACTIVE)
  contactRevealed   Boolean            @default(false)
  contactRevealedAt DateTime?

  lastMessageAt DateTime?
  lastMessageId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  match               Match                @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages            Message[]
  lastMessage         Message?             @relation("ConversationLastMessage", fields: [lastMessageId], references: [id])
  conversationUnlocks ConversationUnlock[]
  userA               User?                @relation("ConversationUserA", fields: [userAId], references: [id])
  userB               User?                @relation("ConversationUserB", fields: [userBId], references: [id])

  @@index([matchId])
  @@index([lastMessageAt])
  @@index([lastActivityAt])
  @@index([stage])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String?
  sender         User?       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  type           MessageType
  body           String?
  voiceUrl       String?
  voiceDuration  Int?
  photoUrl       String?
  contactValue   String?
  readAt         DateTime?
  createdAt      DateTime    @default(now())

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastMessageFor Conversation? @relation("ConversationLastMessage")

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ---------------------------------------------------------------------------
// Wallet & Transactions
// ---------------------------------------------------------------------------

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model CoinPurchase {
  id                String             @id @default(uuid())
  userId            String
  provider          PaymentProvider
  providerReference String?            @unique
  packageId         String
  amountPaid        Decimal            @db.Decimal(10, 2)
  currency          String
  coinsPurchased    Int
  status            CoinPurchaseStatus @default(PENDING)
  metadata          Json?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([status])
}

model WalletTransaction {
  id            String                  @id @default(uuid())
  walletId      String
  userId        String
  type          WalletTransactionType
  reason        WalletTransactionReason
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  referenceType WalletReferenceType?
  referenceId   String?
  metadata      Json?
  createdAt     DateTime                @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([reason])
  @@index([referenceType])
  @@index([referenceId])
  @@index([createdAt])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

