generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  DELETED
  BANNED
}

enum AuthProviderType {
  LOCAL
  GOOGLE
  APPLE
}

enum Gender {
  WOMAN
  MAN
  NON_BINARY
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MediaStatus {
  ACTIVE
  DELETED
}

enum MediaModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

// ─── User / Auth ──────────────────────────────────────────────────────────

model User {
  id            String  @id @default(uuid())
  email         String  @unique
  passwordHash  String?
  phone         String? @unique
  whatsappPhone String?

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)
  verified      Boolean @default(false)

  role   UserRole   @default(USER)
  status UserStatus @default(ACTIVE)

  isActive    Boolean @default(true)
  isSuspended Boolean @default(false)

  pausedAt             DateTime?
  pausedReason         String?
  pausedAdditionalNote String?

  deletedAt             DateTime?
  permanentDeletionAt   DateTime?
  deletedReason         String?
  deletedAdditionalNote String?

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authProviders      AuthProvider[]
  sessions           AuthSession[]
  wallet             Wallet?
  profile            Profile?
  onboardingProgress OnboardingProgress?
  profilePhotos      ProfilePhoto[]
  voiceAnswers       VoiceAnswer[]
}

model AuthProvider {
  id          String           @id @default(uuid())
  userId      String
  provider    AuthProviderType
  providerUid String
  linkedAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Profile ──────────────────────────────────────────────────────────────

model Profile {
  id     String @id @default(uuid())
  userId String @unique

  firstName String
  lastName  String
  birthDate DateTime
  gender    Gender

  originCountry    String
  residenceCountry String
  residenceCity    String

  ethnicity  String?
  languages  String[]
  occupation String

  religion           String
  religionImportance String

  drinking          String
  smoking           String
  socialLife        String
  fitnessImportance String

  moneyStyle          String
  relocationFeelings  String
  financialStatus     String
  childrenPreference  String
  personalCommStyle   String
  personalTuesdayVibe String

  aboutMe String

  onboardingCompleted Boolean   @default(false)
  completedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profilePhotos ProfilePhoto[]
  voiceAnswers  VoiceAnswer[]
}

// ─── Onboarding Cache ─────────────────────────────────────────────────────

model OnboardingProgress {
  id     String @id @default(uuid())
  userId String @unique

  status            OnboardingStatus @default(NOT_STARTED)
  currentStep       Int              @default(1)
  completedSections String[]         @default([])
  draftData         Json?
  draftVersion      Int              @default(1)

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Profile Photos ───────────────────────────────────────────────────────

model ProfilePhoto {
  id        String @id @default(uuid())
  userId    String
  profileId String

  url      String
  publicId String
  mimeType String
  size     Int

  position  Int
  isPrimary Boolean @default(false)

  status           MediaStatus           @default(ACTIVE)
  moderationStatus MediaModerationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, position])
  @@index([userId])
  @@index([profileId])
}

// ─── Voice Prompts / Answers ──────────────────────────────────────────────

model VoicePrompt {
  id       String  @id @default(uuid())
  question String
  category String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers VoiceAnswer[]
}

model VoiceAnswer {
  id            String @id @default(uuid())
  userId        String
  profileId     String
  voicePromptId String

  url      String
  publicId String
  mimeType String
  size     Int

  durationSeconds Int?
  transcript      String?

  status           MediaStatus           @default(ACTIVE)
  moderationStatus MediaModerationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  voicePrompt VoicePrompt @relation(fields: [voicePromptId], references: [id], onDelete: Restrict)

  @@unique([profileId, voicePromptId])
  @@index([userId])
  @@index([profileId])
  @@index([voicePromptId])
}