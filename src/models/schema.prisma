generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  DELETED
  BANNED
}

enum AuthProviderType {
  LOCAL
  GOOGLE
  APPLE
}

enum Gender {
  WOMAN
  MAN
  NON_BINARY
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MediaStatus {
  ACTIVE
  DELETED
}

enum MediaModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum MatchRequestType {
  LIKE
  PASS
  SUPER_LIKE
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum MatchStatus {
  ACTIVE
  UNMATCHED
  BLOCKED
}

enum MatchResultReason {
  COMPATIBLE
  LOW_SCORE
  OUTSIDE_PREFERENCE
  ALREADY_REQUESTED
  ALREADY_MATCHED
  USER_INACTIVE
}

// ─── User / Auth ──────────────────────────────────────────────────────────

model User {
  id            String  @id @default(uuid())
  email         String  @unique
  passwordHash  String?
  phone         String? @unique
  whatsappPhone String?

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)
  verified      Boolean @default(false)

  role   UserRole   @default(USER)
  status UserStatus @default(ACTIVE)

  isActive    Boolean @default(true)
  isSuspended Boolean @default(false)

  pausedAt             DateTime?
  pausedReason         String?
  pausedAdditionalNote String?

  deletedAt             DateTime?
  permanentDeletionAt   DateTime?
  deletedReason         String?
  deletedAdditionalNote String?

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authProviders      AuthProvider[]
  sessions           AuthSession[]
  wallet             Wallet?
  profile            Profile?
  onboardingProgress OnboardingProgress?
  profilePhotos      ProfilePhoto[]
  voiceAnswers       VoiceAnswer[]

  matchPreference MatchPreference?

  sentMatchRequests     MatchRequest[] @relation("SentMatchRequests")
  receivedMatchRequests MatchRequest[] @relation("ReceivedMatchRequests")

  compatibilityAsUserA CompatibilityScore[] @relation("CompatibilityUserA")
  compatibilityAsUserB CompatibilityScore[] @relation("CompatibilityUserB")

  matchesAsUserA Match[] @relation("MatchUserA")
  matchesAsUserB Match[] @relation("MatchUserB")

  viewedMatchResults    MatchResult[] @relation("ViewerMatchResults")
  candidateMatchResults MatchResult[] @relation("CandidateMatchResults")
}

model AuthProvider {
  id          String           @id @default(uuid())
  userId      String
  provider    AuthProviderType
  providerUid String
  linkedAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Profile ──────────────────────────────────────────────────────────────

model Profile {
  id     String @id @default(uuid())
  userId String @unique

  firstName String
  lastName  String
  birthDate DateTime
  gender    Gender

  originCountry    String
  residenceCountry String
  residenceCity    String

  ethnicity  String?
  languages  String[]
  occupation String

  religion           String
  religionImportance String

  drinking          String
  smoking           String
  socialLife        String
  fitnessImportance String

  moneyStyle          String
  relocationFeelings  String
  financialStatus     String
  childrenPreference  String
  personalCommStyle   String
  personalTuesdayVibe String

  aboutMe String

  onboardingCompleted Boolean   @default(false)
  completedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profilePhotos ProfilePhoto[]
  voiceAnswers  VoiceAnswer[]
}

// ─── Onboarding Cache ─────────────────────────────────────────────────────

model OnboardingProgress {
  id     String @id @default(uuid())
  userId String @unique

  status            OnboardingStatus @default(NOT_STARTED)
  currentStep       Int              @default(1)
  completedSections String[]         @default([])
  draftData         Json?
  draftVersion      Int              @default(1)

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Profile Photos ───────────────────────────────────────────────────────

model ProfilePhoto {
  id        String @id @default(uuid())
  userId    String
  profileId String

  url      String
  publicId String
  mimeType String
  size     Int

  position  Int
  isPrimary Boolean @default(false)

  status           MediaStatus           @default(ACTIVE)
  moderationStatus MediaModerationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, position])
  @@index([userId])
  @@index([profileId])
}

// ─── Voice Prompts / Answers ──────────────────────────────────────────────

model VoicePrompt {
  id       String  @id @default(uuid())
  question String
  category String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers VoiceAnswer[]
}

model VoiceAnswer {
  id            String @id @default(uuid())
  userId        String
  profileId     String
  voicePromptId String

  url      String
  publicId String
  mimeType String
  size     Int

  durationSeconds Int?
  transcript      String?

  status           MediaStatus           @default(ACTIVE)
  moderationStatus MediaModerationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  voicePrompt VoicePrompt @relation(fields: [voicePromptId], references: [id], onDelete: Restrict)

  @@unique([profileId, voicePromptId])
  @@index([userId])
  @@index([profileId])
  @@index([voicePromptId])
}

// ─── Matching Preferences ─────────────────────────────────────────────────

model MatchPreference {
  id     String @id @default(uuid())
  userId String @unique

  ageRange String
  preferredGenders Gender[]

  locationPreference String
  religionPreference String
  culturePreference  String
  childrenPreference String

  energyDescription String
  communicationStyle String
  tuesdayFeeling     String
  energyMatchStyle   String

  ambitionImportance String
  faithPractice      String
  socialLevel        String
  lifestylePreference String

  financialStabilityPreference String
  financialStagePreference     String

  idealPartnerType String
  matchVoicePrompt String

  minCompatibilityScore Int @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Compatibility Scores ─────────────────────────────────────────────────

model CompatibilityScore {
  id String @id @default(uuid())

  userAId String
  userBId String

  score Int

  profileScore   Int @default(0)
  lifestyleScore Int @default(0)
  valuesScore    Int @default(0)
  locationScore  Int @default(0)

  reasons Json?

  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userA User @relation("CompatibilityUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("CompatibilityUserB", fields: [userBId], references: [id], onDelete: Cascade)

  matchResults MatchResult[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([score])
}

// ─── Match Requests ───────────────────────────────────────────────────────

model MatchRequest {
  id String @id @default(uuid())

  senderId   String
  receiverId String

  type   MatchRequestType   @default(LIKE)
  status MatchRequestStatus @default(PENDING)

  message String?

  respondedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SentMatchRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMatchRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([type])
}

// ─── Matches ──────────────────────────────────────────────────────────────

model Match {
  id String @id @default(uuid())

  userAId String
  userBId String

  status MatchStatus @default(ACTIVE)

  matchedAt   DateTime @default(now())
  unmatchedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([status])
}

// ─── Match Results / Discovery History ────────────────────────────────────

model MatchResult {
  id String @id @default(uuid())

  viewerId    String
  candidateId String

  compatibilityScoreId String?

  score  Int?
  reason MatchResultReason

  shownAt   DateTime @default(now())
  actedAt   DateTime?
  dismissed Boolean  @default(false)

  viewer    User @relation("ViewerMatchResults", fields: [viewerId], references: [id], onDelete: Cascade)
  candidate User @relation("CandidateMatchResults", fields: [candidateId], references: [id], onDelete: Cascade)

  compatibilityScore CompatibilityScore? @relation(fields: [compatibilityScoreId], references: [id], onDelete: SetNull)

  @@unique([viewerId, candidateId])
  @@index([viewerId])
  @@index([candidateId])
  @@index([reason])
  @@index([dismissed])
}