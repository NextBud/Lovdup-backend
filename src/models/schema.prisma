generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model RefreshSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @updatedAt
  expiresAt        DateTime
  revokedAt        DateTime?
  isRevoked        Boolean   @default(false)
  rotationCount    Int       @default(0)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  passwordHash           String?
  phone                  String?               @unique
  whatsappPhone          String?
  emailVerified          Boolean               @default(false)
  phoneVerified          Boolean               @default(false)
  verified               Boolean               @default(false)
  role                   UserRole              @default(USER)
  status                 UserStatus            @default(ACTIVE)
  isActive               Boolean               @default(true)
  isSuspended            Boolean               @default(false)
  pausedAt               DateTime?
  pausedReason           String?
  pausedAdditionalNote   String?
  deletedAt              DateTime?
  permanentDeletionAt    DateTime?
  deletedReason          String?
  deletedAdditionalNote  String?
  lastLoginAt            DateTime?
  lastActiveAt           DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  photosProcessingStatus MediaProcessingStatus @default(UPLOADING)
  voiceProcessingStatus  MediaProcessingStatus @default(UPLOADING)
  authProviders          AuthProvider[]
  blocksReceived         Block[]               @relation("BlocksReceived")
  blocksMade             Block[]               @relation("BlocksMade")
  compatibilityAsUserA   CompatibilityScore[]  @relation("CompatibilityUserA")
  compatibilityAsUserB   CompatibilityScore[]  @relation("CompatibilityUserB")
  matchesAsUserA         Match[]               @relation("MatchUserA")
  matchesAsUserB         Match[]               @relation("MatchUserB")
  matchPreference        MatchPreference?
  receivedMatchRequests  MatchRequest[]        @relation("ReceivedMatchRequests")
  sentMatchRequests      MatchRequest[]        @relation("SentMatchRequests")
  candidateMatchResults  MatchResult[]         @relation("CandidateMatchResults")
  viewedMatchResults     MatchResult[]         @relation("ViewerMatchResults")
  onboardingMedia        OnboardingMedia[]
  onboardingProgress     OnboardingProgress?
  profile                Profile?
  profilePhotos          ProfilePhoto[]
  refreshSessions        RefreshSession[]
  voiceAnswers           VoiceAnswer[]
  wallet                 Wallet?
  walletTransactions     WalletTransaction[]
}

model AuthProvider {
  id          String           @id @default(uuid())
  userId      String
  provider    AuthProviderType
  providerUid String
  linkedAt    DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
}

model OnboardingProgress {
  id                String           @id @default(uuid())
  userId            String           @unique
  status            OnboardingStatus @default(NOT_STARTED)
  maxReachedStep    Int              @default(1)
  currentStep       Int              @default(1)
  completedSections String[]         @default([])
  draftData         Json?
  draftVersion      Int              @default(1)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OnboardingMedia {
  id        String   @id @default(uuid())
  userId    String
  url       String
  publicId  String
  mimeType  String
  size      Int
  mediaType String
  position  Int?
  promptId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mediaType])
}

// ---------------------------------------------------------------------------
// Profile — top-level container, no data fields itself
// ---------------------------------------------------------------------------

model Profile {
  id                     String                @id @default(uuid())
  userId                 String                @unique
  onboardingCompleted    Boolean               @default(false)
  completedAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  completionPercent      Int                   @default(0)
  photosProcessingStatus MediaProcessingStatus @default(UPLOADING)
  voiceProcessingStatus  MediaProcessingStatus @default(UPLOADING)
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity               ProfileIdentity?
  lifestyle              ProfileLifestyle?
  narrative              ProfileNarrative?
  profilePhotos          ProfilePhoto[]
  values                 ProfileValues?
  voiceAnswers           VoiceAnswer[]
}

// ---------------------------------------------------------------------------
// ProfileIdentity — who you are
// ---------------------------------------------------------------------------

model ProfileIdentity {
  id               String   @id @default(uuid())
  profileId        String   @unique
  firstName        String
  lastName         String
  birthDate        DateTime
  gender           Gender
  originCountry    String
  residenceCountry String
  residenceCity    String
  ethnicity        String?
  languages        String[]
  occupation       String
  // Added: relationship intent is an identity-level field
  relationshipIntention String?
  // Added: education level
  education        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// ProfileLifestyle — how you live
// ---------------------------------------------------------------------------

model ProfileLifestyle {
  id                 String   @id @default(uuid())
  profileId          String   @unique
  drinking           String
  smoking            String
  socialLife         String
  fitnessImportance  String
  moneyStyle         String
  relocationFeelings String
  financialStatus    String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  profile            Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// ProfileValues — what you believe and want
// ---------------------------------------------------------------------------

model ProfileValues {
  id                  String   @id @default(uuid())
  profileId           String   @unique
  religion            String
  religionImportance  String
  childrenPreference  String
  // Added: whether user currently has children (distinct from wanting them)
  hasChildren         Boolean  @default(false)
  personalCommStyle   String
  personalTuesdayVibe String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// ProfileNarrative — your story
// ---------------------------------------------------------------------------

model ProfileNarrative {
  id        String   @id @default(uuid())
  profileId String   @unique
  aboutMe   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProfilePhoto {
  id               String                @id @default(uuid())
  userId           String
  profileId        String
  url              String
  publicId         String
  mimeType         String
  size             Int
  position         Int
  isPrimary        Boolean               @default(false)
  status           MediaStatus           @default(ACTIVE)
  moderationStatus MediaModerationStatus @default(PENDING)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  profile          Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, position])
  @@index([userId])
  @@index([profileId])
}

model VoicePrompt {
  id        String        @id @default(uuid())
  question  String
  category  String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  answers   VoiceAnswer[]
}

model VoiceAnswer {
  id                  String                @id @default(uuid())
  userId              String
  profileId           String
  voicePromptId       String
  url                 String
  publicId            String
  mimeType            String
  size                Int
  durationSeconds     Int?
  transcript          String?
  status              MediaStatus           @default(ACTIVE)
  moderationStatus    MediaModerationStatus @default(PENDING)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  language            String?
  processingError     String?
  transcriptionStatus String?
  waveformUrl         String?
  profile             Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  voicePrompt         VoicePrompt           @relation(fields: [voicePromptId], references: [id])

  @@unique([profileId, voicePromptId])
  @@index([userId])
  @@index([profileId])
  @@index([voicePromptId])
}

// ---------------------------------------------------------------------------
// MatchPreference — what the viewer is looking for
// ageRange string replaced with ageMin / ageMax integers for query use.
// ---------------------------------------------------------------------------

model MatchPreference {
  id                           String   @id @default(uuid())
  userId                       String   @unique

  // Who
  preferredGenders             Gender[]
  // CHANGED: was ageRange String — split into usable integers
  ageMin                       Int      @default(18)
  ageMax                       Int      @default(99)

  // Where
  locationPreference           String   // "Same city" | "Same country" | "Anywhere"

  // Values
  religionPreference           String   // specific religion or "Open to all"
  culturePreference            String
  childrenPreference           String   // preference for partner's children status
  faithPractice                String

  // Personality & energy
  energyDescription            String
  communicationStyle           String
  tuesdayFeeling               String
  energyMatchStyle             String
  ambitionImportance           String

  // Lifestyle
  socialLevel                  String
  lifestylePreference          String   // preferred drinking/smoking tolerance

  // Financial
  financialStabilityPreference String
  financialStagePreference     String

  // Open-ended intent
  idealPartnerType             String
  matchVoicePrompt             String

  // Minimum score a candidate must reach to be shown
  minCompatibilityScore        Int      @default(50)

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  user                         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompatibilityScore {
  id             String        @id @default(uuid())
  userAId        String
  userBId        String
  score          Int
  // Sub-scores for transparency / debugging
  identityScore  Int           @default(0)  // was profileScore
  lifestyleScore Int           @default(0)
  valuesScore    Int           @default(0)
  locationScore  Int           @default(0)
  reasons        Json?
  calculatedAt   DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  userA          User          @relation("CompatibilityUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB          User          @relation("CompatibilityUserB", fields: [userBId], references: [id], onDelete: Cascade)
  matchResults   MatchResult[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([score])
}

model MatchRequest {
  id           String             @id @default(uuid())
  senderId     String
  receiverId   String
  type         MatchRequestType   @default(LIKE)
  status       MatchRequestStatus @default(PENDING)
  message      String?
  respondedAt  DateTime?
  expiresAt    DateTime?
  voiceNoteUrl String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  receiver     User               @relation("ReceivedMatchRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender       User               @relation("SentMatchRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([type])
}

model Match {
  id          String      @id @default(uuid())
  userAId     String
  userBId     String
  status      MatchStatus @default(ACTIVE)
  matchedAt   DateTime    @default(now())
  unmatchedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userA       User        @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User        @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([status])
}

model MatchResult {
  id                   String              @id @default(uuid())
  viewerId             String
  candidateId          String
  compatibilityScoreId String?
  rank                 Int?
  score                Int?
  reason               MatchResultReason
  shownAt              DateTime            @default(now())
  actedAt              DateTime?
  dismissed            Boolean             @default(false)
  candidate            User                @relation("CandidateMatchResults", fields: [candidateId], references: [id], onDelete: Cascade)
  compatibilityScore   CompatibilityScore? @relation(fields: [compatibilityScoreId], references: [id])
  viewer               User                @relation("ViewerMatchResults", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([viewerId, candidateId])
  @@index([viewerId])
  @@index([candidateId])
  @@index([reason])
  @@index([dismissed])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balance      Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id            String                  @id @default(uuid())
  walletId      String
  userId        String
  type          WalletTransactionType
  reason        WalletTransactionReason
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  description   String?
  metadata      Json?
  createdAt     DateTime                @default(now())
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([reason])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  DELETED
  BANNED
}

enum AuthProviderType {
  LOCAL
  GOOGLE
  APPLE
  FIREBASE
}

enum Gender {
  WOMAN
  MAN
  NON_BINARY
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MediaStatus {
  ACTIVE
  DELETED
}

enum MediaProcessingStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum MediaModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum MatchRequestType {
  // PASS removed — a pass is the absence of a request, not a request type.
  // Store passes in a separate MatchPass table if tracking is needed.
  LIKE
  SUPER_LIKE
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum MatchStatus {
  ACTIVE
  UNMATCHED
  BLOCKED
}

enum MatchResultReason {
  COMPATIBLE
  LOW_SCORE
  OUTSIDE_PREFERENCE
  ALREADY_REQUESTED
  ALREADY_MATCHED
  USER_INACTIVE
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletTransactionReason {
  REQUEST_NEW_MATCHES
  START_STAGE_1
  START_STAGE_2
  START_STAGE_3
  START_STAGE_4
  COMPLIMENT_PICTURE
  ADMIN_ADJUSTMENT
}
